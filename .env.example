# Kalshi credentials
# Sign up at: https://kalshi.com
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Or use API key (preferred, generate at kalshi.com/account/api-keys)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=./kalshi_key.pem

# Anthropic API key
ANTHROPIC_API_KEY=

# Bot settings
DRY_RUN=true
MIN_EDGE_PCT=8
MAX_BET_PCT=15
DAILY_STOP_LOSS_PCT=20
POLL_INTERVAL_MS=10000
MIN_LIQUIDITY_USD=500

# Dashboard
DASHBOARD_PORT=4242
