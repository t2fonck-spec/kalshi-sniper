# Kalshi credentials
# Sign up at: https://kalshi.com
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Or use API key (preferred, generate at kalshi.com/account/api-keys)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=./kalshi_key.pem

# Anthropic API key
ANTHROPIC_API_KEY=

# Bot settings
DRY_RUN=true
MIN_EDGE_PCT=8
MAX_BET_PCT=15
DAILY_STOP_LOSS_PCT=20
POLL_INTERVAL_MS=10000
MIN_LIQUIDITY_USD=500

# Dashboard
DASHBOARD_PORT=4242

# Sports Arbitrage Scanner (The Odds API)
# Sign up at: https://the-odds-api.com (free tier: 500 req/month)
ODDS_API_KEY=
ARB_POLL_HOURS=8
ARB_MIN_PROFIT_PCT=2.0
ARB_STAKE=100
ARB_SPORTS=americanfootball_nfl,basketball_nba,baseball_mlb,icehockey_nhl,soccer_epl,soccer_uefa_champs_league
ARB_REGIONS=us,uk,eu,au
